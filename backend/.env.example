# Copy this to .env and fill in your values
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key
DEBUG=False
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1

# Supabase / Render PostgreSQL — use DATABASE_URL in production
# Supabase: Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Or use individual vars for local dev
DB_NAME=pms_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=480
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS — your Vercel deployment URL
FRONTEND_URL=https://your-app.vercel.app
