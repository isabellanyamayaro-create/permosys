# Local development: copy this to .env
# Deployment: configure these values as platform environment variables
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key
DEBUG=False
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1

# Supabase / Render PostgreSQL — use DATABASE_URL in production
# Supabase: Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Or use individual vars for local dev
DB_NAME=pms_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=480
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS primary frontend origin
# Local: FRONTEND_URL=http://localhost:3000
# Cloud: FRONTEND_URL=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Optional additional allowed origins (comma-separated)
# EXTRA_ALLOWED_ORIGINS=http://localhost:3000,https://staging-your-app.vercel.app

# Email / SMTP (Gmail example)
# Use an App Password if your account has 2FA enabled
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=replace-with-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
